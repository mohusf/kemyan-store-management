# ==============================================================================
# KEMYAN Store Management System - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# Lines beginning with # are comments and are ignored.
# ==============================================================================

# ──────────────────────── General ────────────────────────
NODE_ENV=development            # development | staging | production
PORT=3000                       # Backend API listen port
TZ=Asia/Riyadh                  # Server timezone (keep Asia/Riyadh for KSA)
DEFAULT_LANGUAGE=ar             # Default UI language (ar | en)

# ──────────────────────── Database (PostgreSQL) ──────────
DATABASE_URL=postgres://kemyan:kemyan_dev_password@localhost:5432/kemyan_store
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kemyan
DB_PASSWORD=kemyan_dev_password
DB_DATABASE=kemyan_store
DB_SCHEMA=public
DB_SSL=false                    # Set to true for production (Azure/STC)
DB_LOGGING=false                # Enable SQL query logging
DB_POOL_MAX=20                  # Max connections in pool
DB_IDLE_TIMEOUT=30000           # Idle connection timeout (ms)

# ──────────────────────── Redis ──────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                 # Leave blank for local dev
REDIS_URL=redis://localhost:6379

# ──────────────────────── Authentication / JWT ───────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION    # Minimum 32-character random string
JWT_EXPIRES_IN=8h                     # Access token lifetime (JWT_EXPIRY)
JWT_REFRESH_EXPIRES_IN=7d             # Refresh token lifetime

# ──────────────────────── CORS ───────────────────────────
CORS_ORIGINS=http://localhost:5173    # Comma-separated allowed origins

# ──────────────────────── File Uploads ───────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760                # 10 MB in bytes

# ──────────────────────── ZATCA (e-Invoicing) ────────────
# Saudi Zakat, Tax and Customs Authority integration for
# electronic invoicing and VAT compliance.
ZATCA_API_URL=https://sandbox.zatca.gov.sa
ZATCA_API_KEY=
ZATCA_CERTIFICATE_PATH=
ZATCA_PRIVATE_KEY_PATH=

# ──────────────────────── SMTP (Email Notifications) ─────
# Used for approval workflow notifications, expiry alerts,
# and compliance reminders.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kemyan.com
SMTP_SECURE=true                # Use TLS

# ──────────────────────── Twilio (SMS Notifications) ─────
# Used for emergency requisition alerts and critical NCR
# notifications sent via SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # E.164 format, e.g. +966XXXXXXXXX

# ──────────────────────── Logging ────────────────────────
LOG_LEVEL=debug                 # debug | info | warn | error
LOG_FORMAT=json                 # json | pretty
